# Backend configuration (read by pydantic-settings). NEVER commit a real .env.
APP_NAME="Carbon Counterfactual API"
CORS_ORIGINS="http://localhost:5173"
# Leave blank to use the deterministic rule-based insights fallback.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
# Frontend (Vite). Empty = same-origin (single-container deploy).
VITE_API_BASE=""
