rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Footprint snapshots are append-only and scoped to an anonymous device id.
    match /footprints/{docId} {
      allow read: if request.query.limit <= 20;
      allow create: if request.resource.data.keys().hasAll(['device_id', 'total_kg', 'timestamp'])
                    && request.resource.data.device_id is string
                    && request.resource.data.total_kg is number;
      allow update, delete: if false;
    }
  }
}
