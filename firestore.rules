rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Append-only footprint snapshots, scoped by anonymous device id.
    match /entries/{entryId} {
      allow read: if request.query.limit <= 20;
      allow create: if request.resource.data.keys().hasAll(['device_id', 'total_kg', 'created_at'])
                    && request.resource.data.device_id is string
                    && request.resource.data.total_kg is number;
      allow update, delete: if false; // immutable
    }
  }
}
